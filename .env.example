# ============================================================
# Dra. Ana Beatriz Lemos Souza — variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha os valores.
# O site funciona SEM essas variáveis (o formulário cai no
# fluxo de WhatsApp). Preencha quando quiser ativar o banco
# de leads e o rastreamento de marketing.
# ============================================================

# --- Supabase (armazenamento de leads/agendamentos) ---
# Sem essas chaves, o formulário continua funcionando e abre o WhatsApp.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de serviço (NUNCA exponha no client). Usada apenas no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# --- Painel admin (proteção por senha) ---
# Defina uma senha para acessar /admin. Deixe em branco para bloquear o painel.
# (Login com comparação constant-time + rate limit; leitura/edição de leads exige
#  SUPABASE_SERVICE_ROLE_KEY acima.)
ADMIN_PASSWORD=
# Segredo opcional para assinar o cookie de sessão do admin (HMAC). Se vazio,
# usa o ADMIN_PASSWORD como segredo. Gere algo aleatório e longo em produção.
ADMIN_SESSION_SECRET=

# --- Rastreamento / Marketing ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=

# --- Site ---
# URL pública (usada em sitemap, canonical, Open Graph). Ex.: https://draanabeatriz.com.br
NEXT_PUBLIC_SITE_URL=https://www.draanabeatrizodonto.com.br
